        "@axon-official/axon-darwin-x64": "0.2.0-dev",
        "@axon-official/axon-linux-arm64": "0.2.0-dev",
        "@axon-official/axon-linux-x64": "0.2.0-dev",
        "@axon-official/axon-win32-arm64": "0.2.0-dev",
        "@axon-official/axon-win32-x64": "0.2.0-dev"
